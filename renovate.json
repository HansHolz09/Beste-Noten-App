{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "prCreation": "immediate",
  "automergeType": "pr",
  "platformAutomerge": false,
  "packageRules": [
    {
      "description": "Ignored versions",
      "matchPackageNames": [
        "/.*/"
      ],
      "allowedVersions": "!/(^|[.+_-])(snapshot|dev|compat)([0-9.+_-]|$)/i"
    },
    {
      "description": "Automerge minor updates",
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true
    },
    {
      "description": "Do not automerge major and patch updates",
      "matchUpdateTypes": [
        "major",
        "patch"
      ],
      "automerge": false
    },
    {
      "description": "Do not automerge prerelease versions",
      "matchNewValue": "/(^|[.+_-])(alpha|beta|rc|eap)([0-9.+_-]|$)/i",
      "automerge": false
    },
    {
      "description": "Automerge all GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    }
  ],
  "ignoreDeps": [
    "io.github.kalinjul.kotlin.multiplatform:oidc-appsupport",
    "io.github.koalaplot:koalaplot-core"
  ]
}