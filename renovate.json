{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "prCreation": "immediate",
  "automergeType": "pr",
  "platformAutomerge": false,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchNewValue": "/(alpha|beta|rc|eap|snapshot)/i",
      "automerge": false
    }
  ]
}